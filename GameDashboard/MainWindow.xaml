<Window x:Class="GameDashboard.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:GameDashboard.ViewModels"
        mc:Ignorable="d"
        d:DataContext="{d:DesignInstance Type=vm:MainViewModel}"
        Title="🎮 Game Dashboard" Height="780" Width="1280"
        WindowStartupLocation="CenterScreen"
        Background="#0F0F1A">

    <Window.Resources>

        <!-- Paleta dark gamer -->
        <SolidColorBrush x:Key="CorFundo"        Color="#0F0F1A"/>
        <SolidColorBrush x:Key="CorPainel"       Color="#1A1A2E"/>
        <SolidColorBrush x:Key="CorCard"         Color="#16213E"/>
        <SolidColorBrush x:Key="CorDestaque"     Color="#E94560"/>
        <SolidColorBrush x:Key="CorTexto"        Color="#EAEAEA"/>
        <SolidColorBrush x:Key="CorTextoSuave"   Color="#8892A4"/>
        <SolidColorBrush x:Key="CorBorda"        Color="#2A2A4A"/>

        <!-- Conversor de URL para imagem -->
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>

        <!-- Estilo do botão principal -->
        <Style x:Key="BotaoAcao" TargetType="Button">
            <Setter Property="Background"   Value="#E94560"/>
            <Setter Property="Foreground"   Value="White"/>
            <Setter Property="FontWeight"   Value="Bold"/>
            <Setter Property="FontSize"     Value="13"/>
            <Setter Property="Padding"      Value="24,10"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor"       Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#FF6B6B"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Background" Value="#444"/>
                                <Setter Property="Foreground" Value="#888"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Estilo do DataGrid -->
        <Style TargetType="DataGrid">
            <Setter Property="Background"           Value="#1A1A2E"/>
            <Setter Property="Foreground"           Value="#EAEAEA"/>
            <Setter Property="BorderThickness"      Value="0"/>
            <Setter Property="RowBackground"        Value="#1A1A2E"/>
            <Setter Property="AlternatingRowBackground" Value="#16213E"/>
            <Setter Property="GridLinesVisibility"  Value="Horizontal"/>
            <Setter Property="HorizontalGridLinesBrush" Value="#2A2A4A"/>
            <Setter Property="ColumnHeaderHeight"   Value="38"/>
            <Setter Property="RowHeight"            Value="34"/>
            <Setter Property="FontSize"             Value="12"/>
            <Setter Property="SelectionMode"        Value="Single"/>
        </Style>

        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background"   Value="#0F0F1A"/>
            <Setter Property="Foreground"   Value="#E94560"/>
            <Setter Property="FontWeight"   Value="Bold"/>
            <Setter Property="Padding"      Value="8,0"/>
            <Setter Property="BorderThickness" Value="0,0,1,2"/>
            <Setter Property="BorderBrush"  Value="#E94560"/>
        </Style>

        <Style TargetType="DataGridRow">
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#2A2A4A"/>
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#E9456033"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Template de Card de Jogo -->
        <DataTemplate x:Key="CardJogoTemplate">
            <Border Background="{StaticResource CorCard}"
                    CornerRadius="10"
                    Margin="6"
                    Width="180"
                    BorderBrush="{StaticResource CorBorda}"
                    BorderThickness="1">
                <Border.Effect>
                    <DropShadowEffect Color="#000000" BlurRadius="12"
                                      Opacity="0.5" ShadowDepth="2"/>
                </Border.Effect>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="120"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Capa do jogo -->
                    <Border Grid.Row="0" CornerRadius="10,10,0,0"
                            ClipToBounds="True">
                        <Image Source="{Binding UrlImagem}"
                               Stretch="UniformToFill"
                               RenderOptions.BitmapScalingMode="HighQuality">
                            <Image.Style>
                                <Style TargetType="Image">
                                    <Setter Property="Opacity" Value="1"/>
                                    <Style.Triggers>
                                        <Trigger Property="Source" Value="{x:Null}">
                                            <Setter Property="Opacity" Value="0"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Image.Style>
                        </Image>
                    </Border>

                    <!-- Gradiente sobre a imagem -->
                    <Border Grid.Row="0" CornerRadius="10,10,0,0">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                <GradientStop Color="Transparent" Offset="0.4"/>
                                <GradientStop Color="#DD0F0F1A"   Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                    </Border>

                    <!-- Nome do jogo -->
                    <TextBlock Grid.Row="1"
                               Text="{Binding Nome}"
                               Foreground="{StaticResource CorTexto}"
                               FontWeight="Bold" FontSize="12"
                               TextWrapping="Wrap" MaxHeight="40"
                               Margin="10,8,10,2"
                               TextTrimming="CharacterEllipsis"/>

                    <!-- Nota -->
                    <StackPanel Grid.Row="2" Orientation="Horizontal"
                                Margin="10,2,10,4">
                        <TextBlock Text="⭐ " FontSize="11"/>
                        <TextBlock Text="{Binding Nota}"
                                   Foreground="#FFD700"
                                   FontWeight="Bold" FontSize="11"/>
                        <TextBlock Text=" / "
                                   Foreground="{StaticResource CorTextoSuave}"
                                   FontSize="11"/>
                        <TextBlock Text="{Binding NotaMaxima}"
                                   Foreground="{StaticResource CorTextoSuave}"
                                   FontSize="11"/>
                    </StackPanel>

                    <!-- Avaliações -->
                    <TextBlock Grid.Row="3"
                               Margin="10,0,10,10"
                               Foreground="{StaticResource CorTextoSuave}"
                               FontSize="10">
                        <Run Text="🗨 "/>
                        <Run Text="{Binding QuantidadeAvaliacoes, StringFormat='{}{0:N0} avaliações'}"/>
                    </TextBlock>
                </Grid>
            </Border>
        </DataTemplate>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="64"/>   <!-- Header -->
            <RowDefinition Height="Auto"/> <!-- KPI Bar -->
            <RowDefinition Height="*"/>    <!-- Conteúdo principal -->
            <RowDefinition Height="28"/>   <!-- Status bar -->
        </Grid.RowDefinitions>

        <!-- ═══════════════════════════════════ HEADER ══ -->
        <Border Grid.Row="0"
                Background="{StaticResource CorPainel}"
                BorderBrush="{StaticResource CorBorda}"
                BorderThickness="0,0,0,1">
            <Grid Margin="24,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal"
                            VerticalAlignment="Center">
                    <TextBlock Text="🎮" FontSize="26" Margin="0,0,12,0"/>
                    <StackPanel>
                        <TextBlock Text="GAME DASHBOARD"
                                   Foreground="{StaticResource CorTexto}"
                                   FontSize="18" FontWeight="Black"
                                   />
                        <TextBlock Text="RAWG Video Games Analytics"
                                   Foreground="{StaticResource CorTextoSuave}"
                                   FontSize="10"/>
                    </StackPanel>
                </StackPanel>

                <Button Grid.Column="1"
                        Content="⟳  ATUALIZAR DADOS"
                        Style="{StaticResource BotaoAcao}"
                        Command="{Binding CarregarJogosCommand}"
                        IsEnabled="{Binding Carregando,
                                   Converter={StaticResource BoolToVis},
                                   ConverterParameter=Inverse}"
                        VerticalAlignment="Center"/>
            </Grid>
        </Border>

        <!-- ═══════════════════════════════════ KPI BAR ══ -->
        <Border Grid.Row="1"
                Background="#12122A"
                Padding="24,12">
            <StackPanel Orientation="Horizontal">

                <!-- KPI: Total de jogos -->
                <Border Background="{StaticResource CorCard}"
                        CornerRadius="8" Padding="20,10"
                        Margin="0,0,12,0"
                        BorderBrush="{StaticResource CorBorda}"
                        BorderThickness="1">
                    <StackPanel>
                        <TextBlock Text="JOGOS NA BASE"
                                   Foreground="{StaticResource CorTextoSuave}"
                                   FontSize="10" FontWeight="Bold"/>
                        <TextBlock Text="{Binding TotalJogos}"
                                   Foreground="{StaticResource CorDestaque}"
                                   FontSize="28" FontWeight="Black"/>
                    </StackPanel>
                </Border>

                <!-- KPI: Melhor nota -->
                <Border Background="{StaticResource CorCard}"
                        CornerRadius="8" Padding="20,10"
                        Margin="0,0,12,0"
                        BorderBrush="{StaticResource CorBorda}"
                        BorderThickness="1">
                    <StackPanel>
                        <TextBlock Text="MELHOR NOTA"
                                   Foreground="{StaticResource CorTextoSuave}"
                                   FontSize="10" FontWeight="Bold"/>
                        <TextBlock Text="{Binding MelhorNota}"
                                   Foreground="#FFD700"
                                   FontSize="28" FontWeight="Black"/>
                    </StackPanel>
                </Border>

                <!-- Loading indicator -->
                <Border VerticalAlignment="Center" Margin="12,0">
                    <StackPanel Orientation="Horizontal"
                                Visibility="{Binding Carregando,
                                             Converter={StaticResource BoolToVis}}">
                        <TextBlock Text="⏳ " FontSize="14"/>
                        <TextBlock Text="Carregando..."
                                   Foreground="{StaticResource CorTextoSuave}"
                                   FontSize="13" VerticalAlignment="Center"/>
                    </StackPanel>
                </Border>

            </StackPanel>
        </Border>

        <!-- ═══════════════════════════════════ MAIN CONTENT ══ -->
        <Grid Grid.Row="2" Margin="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>         <!-- Cards -->
                <ColumnDefinition Width="5"/>         <!-- Splitter -->
                <ColumnDefinition Width="480"/>       <!-- DataGrid -->
            </Grid.ColumnDefinitions>

            <!-- ── Painel de Cards ── -->
            <Border Grid.Column="0"
                    Background="{StaticResource CorFundo}"
                    Padding="12">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0"
                               Text="🏆  GALERIA DE JOGOS"
                               Foreground="{StaticResource CorTexto}"
                               FontSize="13" FontWeight="Bold"
                               Margin="6,4,0,10"/>

                    <ScrollViewer Grid.Row="1"
                                  VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled">
                        <ItemsControl ItemsSource="{Binding Jogos}"
                                      ItemTemplate="{StaticResource CardJogoTemplate}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel Orientation="Horizontal"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                        </ItemsControl>
                    </ScrollViewer>

                    <!-- Placeholder quando lista vazia -->
                    <TextBlock Grid.Row="1"
                               Text="Nenhum jogo carregado.&#x0a;Clique em 'Atualizar Dados' para começar."
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               TextAlignment="Center"
                               Foreground="{StaticResource CorTextoSuave}"
                               FontSize="14">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Jogos.Count}" Value="0">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </Grid>
            </Border>

            <GridSplitter Grid.Column="1"
                          Width="5" HorizontalAlignment="Stretch"
                          Background="{StaticResource CorBorda}"/>

            <!-- ── DataGrid ── -->
            <Border Grid.Column="2"
                    Background="{StaticResource CorPainel}"
                    Padding="12">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0"
                               Text="📊  DADOS ANALÍTICOS"
                               Foreground="{StaticResource CorTexto}"
                               FontSize="13" FontWeight="Bold"
                               Margin="0,4,0,10"/>

                    <DataGrid Grid.Row="1"
                              ItemsSource="{Binding Jogos}"
                              SelectedItem="{Binding JogoSelecionado}"
                              AutoGenerateColumns="False"
                              CanUserAddRows="False"
                              CanUserDeleteRows="False"
                              IsReadOnly="True"
                              EnableRowVirtualization="True">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Nome"
                                                Binding="{Binding Nome}"
                                                Width="*" MinWidth="120"/>
                            <DataGridTextColumn Header="Nota"
                                                Binding="{Binding Nota}"
                                                Width="55"/>
                            <DataGridTextColumn Header="Máx."
                                                Binding="{Binding NotaMaxima}"
                                                Width="45"/>
                            <DataGridTextColumn Header="Jogos"
                                                Binding="{Binding QuantidadeJogos,
                                                          StringFormat='{}{0:N0}'}"
                                                Width="70"/>
                            <DataGridTextColumn Header="Avaliações"
                                                Binding="{Binding QuantidadeAvaliacoes,
                                                          StringFormat='{}{0:N0}'}"
                                                Width="85"/>
                            <DataGridTextColumn Header="Atualizado"
                                                Binding="{Binding AtualizadoEm,
                                                          StringFormat='{}{0:dd/MM/yy}'}"
                                                Width="80"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>
        </Grid>

        <!-- ═══════════════════════════════════ STATUS BAR ══ -->
        <Border Grid.Row="3"
                Background="#0A0A14"
                BorderBrush="{StaticResource CorBorda}"
                BorderThickness="0,1,0,0"
                Padding="16,0">
            <TextBlock Text="{Binding MensagemStatus}"
                       Foreground="{StaticResource CorTextoSuave}"
                       FontSize="11"
                       VerticalAlignment="Center"/>
        </Border>

    </Grid>
</Window>